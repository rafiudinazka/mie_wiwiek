# URL Koneksi Database PostgreSQL dari Supabase
# Format: postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# (Opsional) Konfigurasi Midtrans jika ingin menggunakan payment gateway asli
# PAYMENT_GATEWAY=midtrans
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxx
# MIDTRANS_CLIENT_KEY=SB-Mid-client-xxx
# MIDTRANS_IS_PRODUCTION=false

# (Opsional) Port lokal
# PORT=3001
